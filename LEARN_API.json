  "item": [
    {
      "name": "Get List User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Get List User is Success then Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Deklarasi cukup satu kali saja di sini",
              "const data = pm.response.json();",
              "console.log('>> Jumlah data:', data.length);",
              "",
              "pm.test('List Users is an array[]', () => {",
              "    pm.expect(data).to.be.an('array'); ",
              "});",
              "",
              "// Pengecekan kondisi jumlah data",
              "if (data.length === 0) {",
              "    pm.test('Filter: Not Found', () => {",
              "        pm.expect(data.length).to.equal(0); ",
              "    });",
              "} else if (data.length === 1) {",
              "    pm.test('Filter: 1 item', () => {",
              "        pm.expect(data.length).to.equal(1); ",
              "    });",
              "} else if (data.length > 1) {",
              "    pm.test('Filter: Multiple Items', () => {",
              "        pm.expect(data.length).to.greaterThan(1); ",
              "    });",
              "} else {",
              "    console.log('Data tidak dikenali atau bukan array');",
              "}",
              "",
              "// PENYEMPURNAAN: Hanya jalankan tes pengecekan isi jika array TIDAK kosong",
              "if (data.length > 0) {",
              "    pm.test('List Users has Required id, username, email', () => {",
              "        const listUsers = data[0];",
              "",
              "        pm.expect(listUsers.id).to.be.a('number'); ",
              "        pm.expect(listUsers.username).to.be.a('string').and.not.to.be.empty; ",
              "        pm.expect(listUsers.email).to.be.a('string').and.not.to.be.empty; ",
              "    });",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://jsonplaceholder.typicode.com/users",
          "protocol": "https",
          "host": [
            "jsonplaceholder",
            "typicode",
            "com"
          ],
          "path": [
